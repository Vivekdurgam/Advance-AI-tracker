# Core Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,127.0.0.1,localhost
TIME_ZONE=UTC
LOG_LEVEL=INFO

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_REFERRER_POLICY=strict-origin-when-cross-origin

# CORS / CSRF
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.com

# API throttling
API_ANON_RATE_LIMIT=120/minute

# Database (PostgreSQL on Render preferred)
# Render PostgreSQL will provide this value.
DATABASE_URL=postgresql://user:password@host:5432/database
DB_CONN_MAX_AGE=600
DB_SSL_REQUIRE=True

# SQLite fallback (used only when DATABASE_URL is empty)
SQLITE_PATH=/var/data/db.sqlite3
SQLITE_TIMEOUT_SECONDS=20

# Gunicorn
PORT=8000
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60

# AI provider
GROK_MODEL=llama-3.1-8b-instant
GROK_API_KEY=replace-with-your-api-key
# Optional override:
# For Groq keys (gsk_...): https://api.groq.com/openai/v1
# For xAI keys: https://api.x.ai/v1
GROK_API_BASE_URL=https://api.groq.com/openai/v1
GROK_TIMEOUT_SECONDS=25
GROK_FALLBACK_MODELS=llama-3.1-8b-instant
